      "Ref": "ScaleDownPolicy"
     }
    ],
    "Period": {
     "Fn::FindInMap": [
      "StageVariables",
      {
       "Ref": "Stage"
      },
      "LatencyAlarmPeriod"
     ]
    },
    "Statistic": "Average",
    "Tags": [
     {
      "Key": "gu:cdk:version",
      "Value": "58.1.2"
     },
     {
      "Key": "gu:repo",
      "Value": "guardian/gateway"
     },
     {
      "Key": "Stack",
      "Value": "identity"
     },
     {
      "Key": "Stage",
      "Value": "PROD"
     }
    ],
    "Threshold": {
     "Fn::FindInMap": [
      "StageVariables",
      {
       "Ref": "Stage"
      },
      "LatencyAlarmThreshold"
     ]
    }
   },
   "Condition": "IsProd"
