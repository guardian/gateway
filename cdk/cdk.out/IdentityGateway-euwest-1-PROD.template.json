{
 "Description": "gateway",
 "AWSTemplateFormatVersion": "2010-09-09",
 "Metadata": {
  "gu:cdk:constructs": [],
  "gu:cdk:version": "58.1.2"
 },
 "Mappings": {
  "StageVariables": {
   "CODE": {
    "BaseUri": "profile.code.dev-theguardian.com",
    "DefaultReturnUri": "https://m.code.dev-theguardian.com",
    "MaxInstances": 2,
    "MinInstances": 1,
    "LatencyAlarmThreshold": 5,
    "LatencyAlarmPeriod": 1200
   },
   "PROD": {
    "BaseUri": "profile.theguardian.com",
    "DefaultReturnUri": "https://theguardian.com",
    "MaxInstances": 12,
    "MinInstances": 3,
    "LatencyAlarmThreshold": 0.5,
    "LatencyAlarmPeriod": 60
   },
   "AlarmPriorities": {
    "P1": "CRITICAL Respond Immediately",
    "P2": "URGENT 9-5",
    "P3": "MODERATE"
   }
  }
 },
 "Parameters": {
  "AMI": {
   "Type": "String",
   "Description": "AMI to use in the autoscaling group"
  },
  "App": {
   "Type": "String",
   "Default": "identity-gateway",
   "Description": "Application name"
  },
  "IdapiBaseUrl": {
   "Type": "AWS::SSM::Parameter::Value<String>",
   "Description": "The base url for idapi"
  },
  "SignInPageUrl": {
   "Type": "AWS::SSM::Parameter::Value<String>",
   "Description": "Sign in page URL used as a fallback if auth redirect retrieval fails."
  },
  "OauthBaseUrl": {
   "Type": "AWS::SSM::Parameter::Value<String>",
   "Description": "The base url for social sign-in with google or apple"
  },
  "OktaOrgUrl": {
   "Type": "AWS::SSM::Parameter::Value<String>",
   "Description": "The org url for interacting with okta APIs"
  },
  "MembersDataApiUrl": {
   "Type": "AWS::SSM::Parameter::Value<String>",
   "Description": "The url for members-data-api"
  },
  "RedisHost": {
   "Type": "AWS::SSM::Parameter::Value<String>",
   "Description": "The Redis server URL, used for rate limiting."
  },
  "SentryDsn": {
   "Type": "AWS::SSM::Parameter::Value<String>",
   "Description": "Public data source name for us to send Sentry logs to"
  },
  "CertificateArn": {
   "Type": "String",
   "Description": "ARN of certificate for loadbalancer use."
  },
  "KeyName": {
   "Type": "AWS::EC2::KeyPair::KeyName",
   "Description": "The EC2 Key Pair to allow SSH access to the instances"
  },
  "AlarmEmailAddress": {
   "Type": "String",
   "Description": "Email address to send CloudWatch alerts"
  },
  "PrivateVpcSubnets": {
   "Type": "List<AWS::EC2::Subnet::Id>",
   "Description": "Private VPC Subnet for the EC2 instances."
  },
  "PublicVpcSubnets": {
   "Type": "List<AWS::EC2::Subnet::Id>",
   "Description": "Public VPC Subnet for the ELB"
  },
  "Stack": {
   "Type": "String",
   "Default": "identity",
   "Description": "tag"
  },
  "Stage": {
   "Type": "String",
   "Default": "CODE",
   "AllowedValues": [
    "CODE",
    "PROD"
   ],
   "Description": "Deployment environment"
  },
  "SshAccessSecurityGroup": {
   "Type": "AWS::EC2::SecurityGroup::Id",
   "Description": "Security group that is allowed SSH access to the instances"
  },
  "SsmManagedPolicyArn": {
   "Type": "String",
   "Description": "The ARN for the ssm iam role"
  },
  "VpcId": {
   "Type": "String",
   "Description": "VPC id of VPC for this service to use"
  },
  "KinesisStream": {
   "Type": "AWS::SSM::Parameter::Value<String>",
   "Default": "/account/services/logging.stream/name",
   "Description": "Kinesis Stream name for logging"
  },
  "LoadBalancerLogsS3Bucket": {
   "Type": "String",
   "Description": "S3 Bucket to write ELB access logs to"
  },
  "IdentityArtifactBucket": {
   "Type": "String",
   "Description": "S3 Bucket to read identity artifacts from"
  },
  "IdentityConfigBucket": {
   "Type": "String",
   "Description": "S3 Bucket to read identity config from"
  }
 },
 "Conditions": {
  "IsProd": {
   "Fn::Equals": [
    {
     "Ref": "Stage"
    },
    "PROD"
   ]
  },
  "NotIsProd": {
   "Fn::Not": [
    {
     "Fn::Equals": [
      {
       "Ref": "Stage"
      },
      "PROD"
     ]
    }
   ]
  }
 },
 "Resources": {
  "AppRole": {
   "Type": "AWS::IAM::Role",
   "Properties": {
    "AssumeRolePolicyDocument": {
     "Statement": [
      {
       "Effect": "Allow",
       "Principal": {
        "Service": [
         "ec2.amazonaws.com"
        ]
       },
       "Action": "sts:AssumeRole"
      }
     ]
    },
    "ManagedPolicyArns": [
     {
      "Ref": "SsmManagedPolicyArn"
     }
    ],
    "Path": "/",
    "Policies": [
     {
      "PolicyDocument": {
       "Version": "2012-10-17",
       "Statement": [
        {
         "Effect": "Allow",
         "Action": "s3:GetObject",
         "Resource": [
          {
           "Fn::Sub": "arn:aws:s3:::${IdentityArtifactBucket}/${Stage}/${App}/*"
          }
         ]
        },
        {
         "Effect": "Allow",
         "Action": "s3:GetObject",
         "Resource": [
          {
           "Fn::Sub": "arn:aws:s3:::${IdentityConfigBucket}/${Stage}/${App}/*"
          }
         ]
        },
        {
         "Effect": "Allow",
         "Action": [
          "kinesis:Describe*",
          "kinesis:Put*"
         ],
         "Resource": [
          {
           "Fn::Sub": "arn:aws:kinesis:${AWS::Region}:${AWS::AccountId}:stream/${KinesisStream}"
          }
         ]
        }
       ]
      },
      "PolicyName": "root"
     },
     {
      "PolicyDocument": {
       "Statement": [
        {
         "Effect": "Allow",
         "Action": [
          "ssm:GetParameter"
         ],
         "Resource": [
          {
           "Fn::Sub": "arn:aws:ssm:${AWS::Region}:${AWS::AccountId}:parameter/${Stack}/${App}/${Stage}/*"
          }
         ]
        }
       ]
      },
      "PolicyName": "GetParameters"
     },
     {
      "PolicyDocument": {
       "Version": "2012-10-17",
       "Statement": [
        {
         "Effect": "Allow",
         "Action": "cloudwatch:PutMetricData",
         "Resource": "*"
        }
       ]
      },
      "PolicyName": "PushMetrics"
     },
     {
      "PolicyDocument": {
       "Version": "2012-10-17",
       "Statement": [
        {
         "Effect": "Allow",
         "Action": [
          "autoscaling:DescribeAutoScalingGroups",
          "autoscaling:DescribeAutoScalingInstances"
         ],
         "Resource": "*"
        }
       ]
      },
      "PolicyName": "DescribeASG"
     },
     {
      "PolicyDocument": {
       "Version": "2012-10-17",
       "Statement": [
        {
         "Effect": "Allow",
         "Action": "ses:SendEmail",
         "Resource": "*"
        }
       ]
      },
      "PolicyName": "SendEmailSES"
     },
     {
      "PolicyDocument": {
       "Version": "2012-10-17",
       "Statement": [
        {
         "Effect": "Allow",
         "Action": [
          "ec2messages:AcknowledgeMessage",
          "ec2messages:DeleteMessage",
          "ec2messages:FailMessage",
          "ec2messages:GetEndpoint",
          "ec2messages:GetMessages",
          "ec2messages:SendReply",
          "ssm:UpdateInstanceInformation",
          "ssm:ListInstanceAssociations",
          "ssm:DescribeInstanceProperties",
          "ssm:DescribeDocumentParameters",
          "ssmmessages:CreateControlChannel",
          "ssmmessages:CreateDataChannel",
          "ssmmessages:OpenControlChannel",
          "ssmmessages:OpenDataChannel"
         ],
         "Resource": "*"
        }
       ]
      },
      "PolicyName": "SSMTunnel"
     }
    ],
    "Tags": [
     {
      "Key": "gu:cdk:version",
      "Value": "58.1.2"
     },
     {
      "Key": "gu:repo",
      "Value": "guardian/gateway"
     },
     {
      "Key": "Stack",
      "Value": "identity"
     },
     {
      "Key": "Stage",
      "Value": "PROD"
     }
    ]
   }
  },
  "GithubActionsSESSendEmailsRole": {
   "Type": "AWS::IAM::Role",
   "Properties": {
    "AssumeRolePolicyDocument": {
     "Statement": [
      {
       "Effect": "Allow",
       "Action": "sts:AssumeRoleWithWebIdentity",
       "Principal": {
        "Federated": {
         "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:oidc-provider/token.actions.githubusercontent.com"
        }
       },
       "Condition": {
        "StringLike": {
         "token.actions.githubusercontent.com:sub": {
          "Fn::Sub": "repo:guardian/gateway:*"
         }
        }
       }
      }
     ]
    },
    "Policies": [
     {
      "PolicyDocument": {
       "Version": "2012-10-17",
       "Statement": [
        {
         "Effect": "Allow",
         "Action": "ses:SendEmail",
         "Resource": "*"
        }
       ]
      },
      "PolicyName": "SendEmailSES"
     }
    ],
    "RoleName": "GithubActionsSESSendEmailsRole",
    "Tags": [
     {
      "Key": "gu:cdk:version",
      "Value": "58.1.2"
     },
     {
      "Key": "gu:repo",
      "Value": "guardian/gateway"
     },
     {
      "Key": "Stack",
      "Value": "identity"
     },
     {
      "Key": "Stage",
      "Value": "PROD"
     }
    ]
   },
   "Condition": "NotIsProd"
  },
  "InstanceProfile": {
   "Type": "AWS::IAM::InstanceProfile",
   "Properties": {
    "Path": "/",
    "Roles": [
     {
      "Ref": "AppRole"
     }
    ]
   }
  },
  "LoadBalancerSecurityGroup": {
   "Type": "AWS::EC2::SecurityGroup",
   "Properties": {
    "GroupDescription": "Allow HTTPS traffic and egress to 9233",
    "SecurityGroupEgress": [
     {
      "CidrIp": "0.0.0.0/0",
      "FromPort": 9233,
      "IpProtocol": "tcp",
      "ToPort": 9233
     }
    ],
    "SecurityGroupIngress": [
     {
      "CidrIp": "0.0.0.0/0",
      "FromPort": 443,
      "IpProtocol": "tcp",
      "ToPort": 443
     }
    ],
    "Tags": [
     {
      "Key": "gu:cdk:version",
      "Value": "58.1.2"
     },
     {
      "Key": "gu:repo",
      "Value": "guardian/gateway"
     },
     {
      "Key": "Stack",
      "Value": "identity"
     },
     {
      "Key": "Stage",
      "Value": "PROD"
     }
    ],
    "VpcId": {
     "Ref": "VpcId"
    }
   }
  },
  "InstanceSecurityGroup": {
   "Type": "AWS::EC2::SecurityGroup",
   "Properties": {
    "GroupDescription": "Allow SSH and HTTPS access",
    "SecurityGroupEgress": [
     {
      "CidrIp": "0.0.0.0/0",
      "FromPort": 443,
      "IpProtocol": "tcp",
      "ToPort": 443
     }
    ],
    "SecurityGroupIngress": [
     {
      "FromPort": 9233,
      "IpProtocol": "tcp",
      "SourceSecurityGroupId": {
       "Ref": "LoadBalancerSecurityGroup"
      },
      "ToPort": 9233
     }
    ],
    "Tags": [
     {
      "Key": "gu:cdk:version",
      "Value": "58.1.2"
     },
     {
      "Key": "gu:repo",
      "Value": "guardian/gateway"
     },
     {
      "Key": "Stack",
      "Value": "identity"
     },
     {
      "Key": "Stage",
      "Value": "PROD"
     }
    ],
    "VpcId": {
     "Ref": "VpcId"
    }
   }
  },
  "LaunchTemplate": {
   "Type": "AWS::EC2::LaunchTemplate",
   "Properties": {
    "LaunchTemplateData": {
     "IamInstanceProfile": {
      "Arn": {
       "Fn::GetAtt": "InstanceProfile.Arn"
      }
     },
     "ImageId": {
      "Ref": "AMI"
     },
     "InstanceType": "t4g.small",
     "KeyName": {
      "Ref": "KeyName"
     },
     "SecurityGroupIds": [
      {
       "Ref": "InstanceSecurityGroup"
      },
      {
       "Ref": "SshAccessSecurityGroup"
      }
     ],
     "UserData": {
      "Fn::Base64": {
       "Fn::Sub": [
        "#!/bin/bash -ev\n\nmkdir /etc/gu\n\n# Get Riff Raff deployed artefact S3\naws s3 cp s3://${IdentityArtifactBucket}/${Stage}/${App}/${App}.zip /etc/gu\nunzip -o /etc/gu/${App}.zip -d /etc/gu\n\n# Get Rate Limiter configuration file\n# Try multiple times to the config file. The s3 cp command can fail when called immediately on instance startup.\nwhile true; do\n  if \\\n    aws s3 cp s3://${IdentityConfigBucket}/${Stage}/${App}/.ratelimit.json /etc/gu/.ratelimit.json\n    then break\n  fi\n  sleep 1\ndone\n\n# Setup user\ngroupadd identity-gateway\nuseradd -r -s /usr/bin/nologin -g identity-gateway identity-gateway\nchown -R identity-gateway:identity-gateway /etc/gu\n\n# Setup logs\ntouch /var/log/identity-gateway.log\nchown identity-gateway:identity-gateway /var/log/identity-gateway.log\n\n# Try multiple times to get parameter store values. The SSM command can fail when called immediately on instance startup.\nwhile true; do\n  if \\\n    IDAPI_CLIENT_ACCESS_TOKEN=$(aws ssm get-parameter --name '/${Stack}/${App}/${Stage}/idapi-client-access-token' --with-decryption --region eu-west-1 --query=\"Parameter.Value\" --output=\"text\") && \\\n    APP_SECRET=$(aws ssm get-parameter --name '/${Stack}/${App}/${Stage}/appSecret' --with-decryption --region eu-west-1 --query=\"Parameter.Value\" --output=\"text\") && \\\n    GOOGLE_RECAPTCHA_SITE_KEY=$(aws ssm get-parameter --name '/${Stack}/${App}/${Stage}/recaptcha-site-key' --with-decryption --region eu-west-1 --query=\"Parameter.Value\" --output=\"text\") && \\\n    GOOGLE_RECAPTCHA_SECRET_KEY=$(aws ssm get-parameter --name '/${Stack}/${App}/${Stage}/recaptcha-secret-key' --with-decryption --region eu-west-1 --query=\"Parameter.Value\" --output=\"text\") && \\\n    REDIS_PASSWORD=$(aws ssm get-parameter --name '/${Stack}/${App}/${Stage}/redis-password' --with-decryption --region eu-west-1 --query=\"Parameter.Value\" --output=\"text\") && \\\n    ENCRYPTION_SECRET_KEY=$(aws ssm get-parameter --name '/${Stack}/${App}/${Stage}/encryption-secret-key' --with-decryption --region eu-west-1 --query=\"Parameter.Value\" --output=\"text\") && \\\n    OKTA_API_TOKEN=$(aws ssm get-parameter --name '/${Stack}/${App}/${Stage}/okta-api-token' --with-decryption --region eu-west-1 --query=\"Parameter.Value\" --output=\"text\") && \\\n    OKTA_CUSTOM_OAUTH_SERVER=$(aws ssm get-parameter --name '/${Stack}/${App}/${Stage}/oktaCustomOAuthServer' --with-decryption --region eu-west-1 --query=\"Parameter.Value\" --output=\"text\") && \\\n    OKTA_CLIENT_ID=$(aws ssm get-parameter --name '/${Stack}/${App}/${Stage}/oktaClientId' --with-decryption --region eu-west-1 --query=\"Parameter.Value\" --output=\"text\") && \\\n    OKTA_CLIENT_SECRET=$(aws ssm get-parameter --name '/${Stack}/${App}/${Stage}/oktaClientSecret' --with-decryption --region eu-west-1 --query=\"Parameter.Value\" --output=\"text\")\n    OKTA_IDP_APPLE=$(aws ssm get-parameter --name '/${Stack}/${App}/${Stage}/oktaIdpApple' --with-decryption --region eu-west-1 --query=\"Parameter.Value\" --output=\"text\")\n    OKTA_IDP_GOOGLE=$(aws ssm get-parameter --name '/${Stack}/${App}/${Stage}/oktaIdpGoogle' --with-decryption --region eu-west-1 --query=\"Parameter.Value\" --output=\"text\")\n    OKTA_GUARDIAN_USERS_ALL_GROUP_ID=$(aws ssm get-parameter --name '/${Stack}/${App}/${Stage}/oktaGuardianUsersAllGroupId' --with-decryption --region eu-west-1 --query=\"Parameter.Value\" --output=\"text\")\n    DELETE_ACCOUNT_STEP_FUNCTION_URL=$(aws ssm get-parameter --name '/${Stack}/${App}/${Stage}/deleteAccountStepFunctionUrl' --with-decryption --region eu-west-1 --query=\"Parameter.Value\" --output=\"text\")\n    DELETE_ACCOUNT_STEP_FUNCTION_API_KEY=$(aws ssm get-parameter --name '/${Stack}/${App}/${Stage}/deleteAccountStepFunctionApiKey' --with-decryption --region eu-west-1 --query=\"Parameter.Value\" --output=\"text\")\n    then break\n  fi\n\n  sleep 1\ndone\n\n# systemd setup\ncat > /etc/systemd/system/identity-gateway.service <<EOL\n[Service]\nExecStart=/bin/sh -ec '/usr/bin/node /etc/gu/server.js > /var/log/identity-gateway.log 2>&1'\nRestart=always\nStandardOutput=syslog\nStandardError=syslog\nSyslogIdentifier=identity-gateway\nUser=identity-gateway\nGroup=identity-gateway\nEnvironment=NODE_ENV=production\nEnvironment=PORT=9233\nEnvironment=IDAPI_CLIENT_ACCESS_TOKEN=$IDAPI_CLIENT_ACCESS_TOKEN\nEnvironment=IDAPI_BASE_URL=${IdapiBaseUrl}\nEnvironment=SIGN_IN_PAGE_URL=${SignInPageUrl}\nEnvironment=OAUTH_BASE_URL=${OauthBaseUrl}\nEnvironment=BASE_URI=${BaseUri}\nEnvironment=DEFAULT_RETURN_URI=${DefaultReturnUri}\nEnvironment=STAGE=${Stage}\nEnvironment=IS_HTTPS=true\nEnvironment=APP_SECRET=$APP_SECRET\nEnvironment=GOOGLE_RECAPTCHA_SITE_KEY=$GOOGLE_RECAPTCHA_SITE_KEY\nEnvironment=GOOGLE_RECAPTCHA_SECRET_KEY=$GOOGLE_RECAPTCHA_SECRET_KEY\nEnvironment=ENCRYPTION_SECRET_KEY=$ENCRYPTION_SECRET_KEY\nEnvironment=OKTA_ORG_URL=${OktaOrgUrl}\nEnvironment=OKTA_API_TOKEN=$OKTA_API_TOKEN\nEnvironment=OKTA_CUSTOM_OAUTH_SERVER=$OKTA_CUSTOM_OAUTH_SERVER\nEnvironment=OKTA_CLIENT_ID=$OKTA_CLIENT_ID\nEnvironment=OKTA_CLIENT_SECRET=$OKTA_CLIENT_SECRET\nEnvironment=OKTA_IDP_APPLE=$OKTA_IDP_APPLE\nEnvironment=OKTA_IDP_GOOGLE=$OKTA_IDP_GOOGLE\nEnvironment=OKTA_GUARDIAN_USERS_ALL_GROUP_ID=$OKTA_GUARDIAN_USERS_ALL_GROUP_ID            \nEnvironment=LOGGING_KINESIS_STREAM=${KinesisStream}\nEnvironment=EC2_INSTANCE_ID=$(curl -s http://169.254.169.254/latest/meta-data/instance-id)\nEnvironment=SENTRY_DSN=${SentryDsn}\nEnvironment=REDIS_PASSWORD=$REDIS_PASSWORD\nEnvironment=REDIS_HOST=${RedisHost}\nEnvironment=REDIS_SSL_ON=true\nEnvironment=MEMBERS_DATA_API_URL=${MembersDataApiUrl}\nEnvironment=DELETE_ACCOUNT_STEP_FUNCTION_URL=$DELETE_ACCOUNT_STEP_FUNCTION_URL\nEnvironment=DELETE_ACCOUNT_STEP_FUNCTION_API_KEY=$DELETE_ACCOUNT_STEP_FUNCTION_API_KEY\n\n[Install]\nWantedBy=multi-user.target\nEOL\n\nsystemctl enable identity-gateway\nsystemctl start identity-gateway\n\n",
        {
         "BaseUri": {
          "Fn::FindInMap": [
           "StageVariables",
           {
            "Ref": "Stage"
           },
           "BaseUri"
          ]
         },
         "DefaultReturnUri": {
          "Fn::FindInMap": [
           "StageVariables",
           {
            "Ref": "Stage"
           },
           "DefaultReturnUri"
          ]
         }
        }
       ]
      }
     }
    },
    "LaunchTemplateName": {
     "Fn::Sub": "${Stage}-${Stack}-${App}"
    }
   }
  },
  "TargetGroup": {
   "Type": "AWS::ElasticLoadBalancingV2::TargetGroup",
   "Properties": {
    "HealthCheckIntervalSeconds": 10,
    "HealthCheckPath": "/healthcheck",
    "HealthCheckPort": "9233",
    "HealthCheckProtocol": "HTTP",
    "HealthCheckTimeoutSeconds": 5,
    "HealthyThresholdCount": 2,
    "Matcher": {
     "HttpCode": "200"
    },
    "Name": {
     "Fn::Sub": "${Stage}-${Stack}-${App}"
    },
    "Port": 9233,
    "Protocol": "HTTP",
    "Tags": [
     {
      "Key": "gu:cdk:version",
      "Value": "58.1.2"
     },
     {
      "Key": "gu:repo",
      "Value": "guardian/gateway"
     },
     {
      "Key": "Stack",
      "Value": "identity"
     },
     {
      "Key": "Stage",
      "Value": "PROD"
     }
    ],
    "TargetGroupAttributes": [
     {
      "Key": "deregistration_delay.timeout_seconds",
      "Value": "45"
     }
    ],
    "UnhealthyThresholdCount": 2,
    "VpcId": {
     "Ref": "VpcId"
    }
   },
   "DependsOn": [
    "LoadBalancer"
   ]
  },
  "LoadBalancer": {
   "Type": "AWS::ElasticLoadBalancingV2::LoadBalancer",
   "Properties": {
    "LoadBalancerAttributes": [
     {
      "Key": "access_logs.s3.enabled",
      "Value": "true"
     },
     {
      "Key": "access_logs.s3.bucket",
      "Value": {
       "Ref": "LoadBalancerLogsS3Bucket"
      }
     },
     {
      "Key": "access_logs.s3.prefix",
      "Value": {
       "Fn::Sub": "ELBLogs/${Stack}/${App}/${Stage}"
      }
     }
    ],
    "Name": {
     "Fn::Sub": "${Stack}-${App}-${Stage}"
    },
    "SecurityGroups": [
     {
      "Ref": "LoadBalancerSecurityGroup"
     }
    ],
    "Subnets": {
     "Ref": "PublicVpcSubnets"
    },
    "Tags": [
     {
      "Key": "App",
      "Value": {
       "Ref": "App"
      }
     },
     {
      "Key": "gu:cdk:version",
      "Value": "58.1.2"
     },
     {
      "Key": "gu:repo",
      "Value": "guardian/gateway"
     },
     {
      "Key": "Stack",
      "Value": "identity"
     },
     {
      "Key": "Stage",
      "Value": "PROD"
     }
    ]
   }
  },
  "AutoScalingGroup": {
   "Type": "AWS::AutoScaling::AutoScalingGroup",
   "Properties": {
    "HealthCheckGracePeriod": 300,
    "HealthCheckType": "ELB",
    "LaunchTemplate": {
     "LaunchTemplateId": {
      "Ref": "LaunchTemplate"
     },
     "Version": {
      "Fn::GetAtt": "LaunchTemplate.LatestVersionNumber"
     }
    },
    "MaxSize": {
     "Fn::FindInMap": [
      "StageVariables",
      {
       "Ref": "Stage"
      },
      "MaxInstances"
     ]
    },
    "MinSize": {
     "Fn::FindInMap": [
      "StageVariables",
      {
       "Ref": "Stage"
      },
      "MinInstances"
     ]
    },
    "Tags": [
     {
      "Key": "App",
      "PropagateAtLaunch": true,
      "Value": {
       "Ref": "App"
      }
     },
     {
      "Key": "gu:cdk:version",
      "PropagateAtLaunch": true,
      "Value": "58.1.2"
     },
     {
      "Key": "gu:repo",
      "PropagateAtLaunch": true,
      "Value": "guardian/gateway"
     },
     {
      "Key": "Name",
      "PropagateAtLaunch": true,
      "Value": {
       "Fn::Sub": "${Stage}:${App}"
      }
     },
     {
      "Key": "Stack",
      "PropagateAtLaunch": true,
      "Value": "identity"
     },
     {
      "Key": "Stage",
      "PropagateAtLaunch": true,
      "Value": "PROD"
     }
    ],
    "TargetGroupARNs": [
     {
      "Ref": "TargetGroup"
     }
    ],
    "VPCZoneIdentifier": {
     "Ref": "PrivateVpcSubnets"
    }
   }
  },
  "LoadBalancerListener": {
   "Type": "AWS::ElasticLoadBalancingV2::Listener",
   "Properties": {
    "Certificates": [
     {
      "CertificateArn": {
       "Ref": "CertificateArn"
      }
