    "AlarmDescription": {
     "Fn::Sub": [
      "Scale-Up if latency is greater than ${Threshold} seconds over last ${Period} seconds",
      {
       "Period": {
        "Fn::FindInMap": [
         "StageVariables",
         {
          "Ref": "Stage"
         },
         "LatencyAlarmPeriod"
        ]
       },
       "Threshold": {
        "Fn::FindInMap": [
         "StageVariables",
         {
          "Ref": "Stage"
         },
