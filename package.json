{
	"name": "gateway",
	"version": "1.0.0",
	"author": "idenititydev@theguardian.com",
	"license": "Apache-2.0",
	"private": true,
	"scripts": {
		"build": "ENVIRONMENT=production webpack --mode production && pnpm install --prod --node-linker=hoisted --dir=build --ignore-scripts",
		"build-storybook": "storybook build",
		"build:analyze": "WEBPACK_ANALYZE_BUNDLE=true pnpm run build",
		"clear:cache": "rm -rf ./node_modules/.cache",
		"gen:ratelimit:schema": "ts-node --transpileOnly ./scripts/generate-rate-limit-schema.ts",
		"knip": "knip",
		"lint": "eslint .",
		"lint:fix": "pnpm lint --fix",
		"mock-server": "node util/mock-server.js",
		"playwright": "playwright test",
		"playwright:e2e": "playwright test --project=e2e",
		"playwright:mocked": "playwright test --project=mocked",
		"playwright:report": "playwright show-report",
		"playwright:ui": "playwright test --ui",
		"postinstall": "pnpm run gen:ratelimit:schema",
		"preinstall": "npx only-allow pnpm",
		"prepare": "husky",
		"prettier": "prettier . --check",
		"prettier:fix": "prettier . --write",
		"start": "node ./build/server.js",
		"storybook": "storybook dev -p 6006",
		"test": "pnpm run lint && pnpm run tsc && pnpm run tsc:playwright && pnpm run knip && pnpm run test:unit",
		"test:unit": "jest --ci",
		"tsc": "tsc --noEmit --skipLibCheck --erasableSyntaxOnly",
		"tsc:playwright": "tsc --noEmit --skipLibCheck --project playwright/tsconfig.json",
		"wait-on:mock-server": "wait-on http://localhost:9000/healthcheck -t 60000",
		"wait-on:server": "wait-on https://profile.thegulocal.com/healthcheck -t 60000",
		"watch": "webpack --watch --config webpack.development.js",
		"watch:server": "mkdir -p ./build && touch ./build/server.js && nodemon --inspect ./build/server.js --watch ./build/server.js --watch .ratelimit.json"
	},
